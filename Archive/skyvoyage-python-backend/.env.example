ENVIRONMENT=development
SECRET_KEY=skyvoyage_fastapi_secret_key_minimum_32_characters_long
MONGODB_URL=mongodb://localhost:27017/skyvoyage
DATABASE_NAME=skyvoyage
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3002", "http://localhost:3001"]
ALGORITHM=HS256

# Amadeus API Configuration (REQUIRED FOR LIVE DATA)
# Get your credentials from: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here

# Live API Configuration
USE_LIVE_API=true
BASE_URL=https://test.api.amadeus.com
MAX_FLIGHT_RESULTS=50
CACHE_TTL=300

# Optional: Kiwi API (for future enhancement)
KIWI_API_KEY=your_kiwi_api_key_here

# Optional: AviationStack API (for additional schedules)
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here

# Application Settings
DEBUG=true
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_MINUTES=30
